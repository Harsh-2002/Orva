---
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
const baseTrim = base.replace(/\/$/, '');

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Self-hosted serverless runtime. Functions on your own metal — five kernel-enforced boundaries per call. Node, Python, TypeScript. One binary, one port, zero external dependencies.',
} = Astro.props;

const site = Astro.site ?? new URL('https://harsh-2002.github.io/');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(`${baseTrim}/og.png`, site).href;

const ldJson = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${canonical}#website`,
      url: canonical,
      name: 'Orva',
      description,
      inLanguage: 'en',
      publisher: { '@id': `${canonical}#person` },
    },
    {
      '@type': 'Person',
      '@id': `${canonical}#person`,
      name: 'Harsh',
      url: 'https://github.com/Harsh-2002',
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Orva',
      description,
      url: canonical,
      image: ogImage,
      applicationCategory: 'DeveloperApplication',
      applicationSubCategory: 'Serverless Runtime',
      operatingSystem: 'Linux',
      license: 'https://opensource.org/licenses/MIT',
      author: { '@id': `${canonical}#person` },
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      programmingLanguage: ['JavaScript', 'TypeScript', 'Python'],
      codeRepository: 'https://github.com/Harsh-2002/Orva',
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0E0D17" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="keywords"
      content="self-hosted, serverless, runtime, function-as-a-service, faas, nsjail, sandbox, kata containers, node.js, python, typescript, homelab, docker, kubernetes alternative"
    />
    <meta name="author" content="Harsh" />
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />

    <!-- iOS Safari -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Orva" />
    <meta name="format-detection" content="telephone=no" />
    <!-- Android Chrome -->
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Orva" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Orva — self-hosted serverless runtime" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Orva — self-hosted serverless runtime" />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href={`${baseTrim}/favicon.svg`} />
    <link rel="apple-touch-icon" href={`${baseTrim}/favicon.svg`} />

    <!-- Structured data (schema.org) -->
    <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
  </head>

  <body>
    <slot />

    <!-- Lightbox overlay -->
    <div id="lightbox" aria-hidden="true">
      <button id="lightbox-close" aria-label="Close">×</button>
      <figure>
        <img id="lightbox-img" alt="" />
        <figcaption id="lightbox-cap"></figcaption>
      </figure>
    </div>

    <script>
      // Copy buttons
      document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const sel = btn.getAttribute('data-copy');
          if (!sel) return;
          const target = document.querySelector(sel) as HTMLElement | null;
          if (!target) return;
          const text = target.innerText.trim();
          try {
            await navigator.clipboard.writeText(text);
          } catch {
            const ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            ta.remove();
          }
          const original = btn.textContent;
          btn.textContent = 'Copied';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = original || 'Copy';
            btn.classList.remove('copied');
          }, 1400);
        });
      });

      // Lightbox
      const lb = document.getElementById('lightbox')!;
      const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
      const lbCap = document.getElementById('lightbox-cap')!;
      const lbClose = document.getElementById('lightbox-close')!;
      let lbLast: HTMLElement | null = null;

      const openLb = (trigger: HTMLElement) => {
        const src = trigger.getAttribute('data-lightbox') || '';
        const cap = trigger.getAttribute('data-caption') || '';
        lbImg.src = src;
        lbCap.textContent = cap;
        lb.setAttribute('aria-hidden', 'false');
        lbLast = trigger;
        lbClose.focus();
        document.body.style.overflow = 'hidden';
      };
      const closeLb = () => {
        lb.setAttribute('aria-hidden', 'true');
        lbImg.src = '';
        document.body.style.overflow = '';
        lbLast?.focus();
      };

      document.querySelectorAll<HTMLElement>('[data-lightbox]').forEach((el) => {
        el.addEventListener('click', () => openLb(el));
        el.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            openLb(el);
          }
        });
      });
      lbClose.addEventListener('click', closeLb);
      lb.addEventListener('click', (e) => {
        if (e.target === lb) closeLb();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && lb.getAttribute('aria-hidden') === 'false') closeLb();
      });

      // Smooth-scroll for anchor links with sticky-nav offset
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', (e) => {
          const href = link.getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (!target) return;
          e.preventDefault();
          const top = (target as HTMLElement).getBoundingClientRect().top + window.scrollY - 24;
          window.scrollTo({ top, behavior: 'smooth' });
        });
      });

      // Cursor spotlight — eased lerp toward target pointer position.
      // Lower `ease` = slower / dreamier trail; 0.10 lands at ~99% in ~500ms.
      // The first pointermove snaps the spotlight in (no zoom-in from -9999px),
      // then rAF interpolates each subsequent target.
      const supportsHover = matchMedia('(hover: hover) and (pointer: fine)').matches;
      const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (supportsHover && !reduceMotion) {
        let targetX = 0;
        let targetY = 0;
        let currentX = -1;
        let currentY = -1;
        let rafId = 0;
        const ease = 0.1;
        const tick = () => {
          const dx = targetX - currentX;
          const dy = targetY - currentY;
          currentX += dx * ease;
          currentY += dy * ease;
          document.body.style.setProperty('--cx', currentX.toFixed(1) + 'px');
          document.body.style.setProperty('--cy', currentY.toFixed(1) + 'px');
          if (Math.abs(dx) > 0.4 || Math.abs(dy) > 0.4) {
            rafId = requestAnimationFrame(tick);
          } else {
            // Snap to final on convergence so the value matches the cursor exactly.
            document.body.style.setProperty('--cx', targetX + 'px');
            document.body.style.setProperty('--cy', targetY + 'px');
            rafId = 0;
          }
        };
        document.addEventListener(
          'pointermove',
          (e: PointerEvent) => {
            targetX = e.clientX;
            targetY = e.clientY;
            if (currentX < 0) {
              // First move — seed at cursor position so we don't trail in from off-screen.
              currentX = e.clientX;
              currentY = e.clientY;
            }
            if (!rafId) rafId = requestAnimationFrame(tick);
          },
          { passive: true }
        );
      }
    </script>

    <style is:global>
      #lightbox {
        position: fixed;
        inset: 0;
        z-index: 100;
        background: color-mix(in oklab, var(--bg-deep) 70%, transparent);
        backdrop-filter: blur(14px) saturate(140%);
        -webkit-backdrop-filter: blur(14px) saturate(140%);
        display: none;
        align-items: center;
        justify-content: center;
        padding: clamp(20px, 4vw, 56px);
      }
      #lightbox[aria-hidden='false'] {
        display: flex;
      }
      #lightbox figure {
        max-width: 1280px;
        width: 100%;
        background: transparent;
        border: none;
        padding: 0;
      }
      #lightbox img {
        width: 100%;
        max-height: 78vh;
        object-fit: contain;
        border: none;
        border-radius: 24px;
        display: block;
        background: transparent;
      }
      #lightbox figcaption {
        margin-top: 18px;
        color: var(--fg);
        font-size: 0.875rem;
        text-align: center;
        font-family: var(--mono);
        letter-spacing: 0.02em;
        line-height: 1.55;
      }
      #lightbox-close {
        position: absolute;
        top: clamp(14px, 2vw, 24px);
        right: clamp(14px, 2vw, 24px);
        font-size: 22px;
        color: var(--muted);
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: none;
        line-height: 1;
        font-family: var(--mono);
        transition:
          color 120ms,
          transform 120ms;
      }
      #lightbox-close:hover {
        color: var(--fg);
      }
      #lightbox-close:active {
        transform: scale(0.92);
      }
      @media (max-width: 560px) {
        #lightbox img {
          border-radius: 12px;
          max-height: 70vh;
        }
      }
    </style>
  </body>
</html>
