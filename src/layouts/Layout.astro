---
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
const baseTrim = base.replace(/\/$/, '');

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Self-hosted serverless runtime. Functions on your own metal — five kernel-enforced boundaries per call.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0E0D17" />

    <!-- iOS Safari -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Orva" />
    <meta name="format-detection" content="telephone=no" />
    <!-- Android Chrome -->
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href={`${baseTrim}/favicon.svg`} />
    <link rel="apple-touch-icon" href={`${baseTrim}/favicon.svg`} />
  </head>

  <body>
    <slot />

    <!-- Lightbox overlay -->
    <div id="lightbox" aria-hidden="true">
      <button id="lightbox-close" aria-label="Close">×</button>
      <figure>
        <img id="lightbox-img" alt="" />
        <figcaption id="lightbox-cap"></figcaption>
      </figure>
    </div>

    <script>
      // Copy buttons
      document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const sel = btn.getAttribute('data-copy');
          if (!sel) return;
          const target = document.querySelector(sel) as HTMLElement | null;
          if (!target) return;
          const text = target.innerText.trim();
          try {
            await navigator.clipboard.writeText(text);
          } catch {
            const ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            ta.remove();
          }
          const original = btn.textContent;
          btn.textContent = 'Copied';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = original || 'Copy';
            btn.classList.remove('copied');
          }, 1400);
        });
      });

      // Lightbox
      const lb = document.getElementById('lightbox')!;
      const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
      const lbCap = document.getElementById('lightbox-cap')!;
      const lbClose = document.getElementById('lightbox-close')!;
      let lbLast: HTMLElement | null = null;

      const openLb = (trigger: HTMLElement) => {
        const src = trigger.getAttribute('data-lightbox') || '';
        const cap = trigger.getAttribute('data-caption') || '';
        lbImg.src = src;
        lbCap.textContent = cap;
        lb.setAttribute('aria-hidden', 'false');
        lbLast = trigger;
        lbClose.focus();
        document.body.style.overflow = 'hidden';
      };
      const closeLb = () => {
        lb.setAttribute('aria-hidden', 'true');
        lbImg.src = '';
        document.body.style.overflow = '';
        lbLast?.focus();
      };

      document.querySelectorAll<HTMLElement>('[data-lightbox]').forEach((el) => {
        el.addEventListener('click', () => openLb(el));
        el.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            openLb(el);
          }
        });
      });
      lbClose.addEventListener('click', closeLb);
      lb.addEventListener('click', (e) => {
        if (e.target === lb) closeLb();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && lb.getAttribute('aria-hidden') === 'false') closeLb();
      });

      // Smooth-scroll for anchor links with sticky-nav offset
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', (e) => {
          const href = link.getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (!target) return;
          e.preventDefault();
          const top = (target as HTMLElement).getBoundingClientRect().top + window.scrollY - 24;
          window.scrollTo({ top, behavior: 'smooth' });
        });
      });
    </script>

    <style is:global>
      #lightbox {
        position: fixed;
        inset: 0;
        z-index: 100;
        background: color-mix(in oklab, var(--bg-deep) 70%, transparent);
        backdrop-filter: blur(14px) saturate(140%);
        -webkit-backdrop-filter: blur(14px) saturate(140%);
        display: none;
        align-items: center;
        justify-content: center;
        padding: clamp(20px, 4vw, 56px);
      }
      #lightbox[aria-hidden='false'] { display: flex; }
      #lightbox figure {
        max-width: 1280px;
        width: 100%;
        background: transparent;
        border: none;
        padding: 0;
      }
      #lightbox img {
        width: 100%;
        max-height: 78vh;
        object-fit: contain;
        border: none;
        border-radius: 10px;
        display: block;
        background: transparent;
      }
      #lightbox figcaption {
        margin-top: 18px;
        color: var(--fg);
        font-size: 0.875rem;
        text-align: center;
        font-family: var(--mono);
        letter-spacing: 0.02em;
        line-height: 1.55;
      }
      #lightbox-close {
        position: absolute;
        top: clamp(14px, 2vw, 24px);
        right: clamp(14px, 2vw, 24px);
        font-size: 22px;
        color: var(--muted);
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: none;
        line-height: 1;
        font-family: var(--mono);
        transition: color 120ms, transform 120ms;
      }
      #lightbox-close:hover { color: var(--fg); }
      #lightbox-close:active { transform: scale(0.92); }
      @media (max-width: 560px) {
        #lightbox img { border-radius: 8px; max-height: 70vh; }
      }
    </style>
  </body>
</html>
