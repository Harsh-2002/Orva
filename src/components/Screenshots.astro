---
const base = import.meta.env.BASE_URL;

const shots = [
  { file: 'system-overview-dashboard', title: 'System Overview', desc: 'Live metrics, warm pools, response-time percentiles' },
  { file: 'functions-list', title: 'Functions', desc: 'Every deployed handler, runtime, resources, last deploy date' },
  { file: 'function-editor', title: 'Editor', desc: 'Write and deploy code directly in the browser' },
  { file: 'distributed-traces', title: 'Traces', desc: 'Automatic causal waterfall across HTTP, F2F, and background jobs' },
  { file: 'activity-live-feed', title: 'Activity', desc: 'Live feed of every API call, CLI command, and webhook delivery' },
  { file: 'invocation-logs', title: 'Invocation Logs', desc: 'Every execution with request, response, duration, and trace link' },
  { file: 'built-in-docs', title: 'Built-in Docs', desc: 'Full reference always at /web/docs — no tab-switching' },
  { file: 'firewall-and-dns', title: 'Firewall & DNS', desc: 'Per-function egress rules, custom resolvers, blocklist' },
  { file: 'settings-oauth', title: 'Settings', desc: 'Storage, account, and OAuth-connected apps' },
];
---

<section id="screenshots">
  <div class="inner">
    <div class="hd" data-reveal>
      <span class="eyebrow">Dashboard</span>
      <h2 class="section-title">Everything the operator needs</h2>
      <p class="section-sub">Nothing they don't. Click any screenshot to view full size.</p>
    </div>

    <div class="grid">
      {shots.map((s, i) => {
        const src = `${base}/screenshots/${s.file}.jpeg`;
        const caption = `${s.title} — ${s.desc}`;
        return (
          <figure class="card" data-reveal style={`--si:${i % 3}`}>
            <div
              class="thumb"
              role="button"
              tabindex="0"
              data-lightbox={src}
              data-caption={caption}
              aria-label={`View ${s.title} full size`}
            >
              <img src={src} alt={s.title} loading="lazy" decoding="async" width="800" height="500" />
              <div class="overlay">
                <span class="expand-pill">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
                  View
                </span>
              </div>
            </div>
            <figcaption>
              <strong>{s.title}</strong>
              <span>{s.desc}</span>
            </figcaption>
          </figure>
        );
      })}
    </div>
  </div>
</section>

<style>
  #screenshots { padding: clamp(64px, 8vw, 88px) 0; }
  #screenshots .inner { max-width: 1360px; }
  .hd { margin-bottom: 36px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .card { display: flex; flex-direction: column; gap: 10px; }
  .thumb {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    aspect-ratio: 16 / 10;
    background: var(--surface);
    cursor: pointer;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 240ms ease;
  }
  .thumb:hover img { transform: scale(1.03); }
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    background: rgba(17,16,25,0.55);
    transition: opacity 160ms;
  }
  .thumb:hover .overlay,
  .thumb:focus-visible .overlay { opacity: 1; }
  .expand-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--fg);
    background: rgba(25,24,41,0.8);
    border: 1px solid rgba(238,234,248,0.2);
    padding: 5px 13px;
    border-radius: 9999px;
    backdrop-filter: blur(4px);
  }
  figcaption { display: flex; flex-direction: column; gap: 3px; }
  figcaption strong { font-size: 0.8125rem; font-weight: 600; color: var(--fg); }
  figcaption span { font-size: 0.75rem; color: var(--muted); line-height: 1.45; }

  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .grid { grid-template-columns: 1fr; } }
</style>
