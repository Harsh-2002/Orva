---
---

<section id="cta">
  <div class="inner">
    <div class="wrap" data-reveal>
      <h2>Deploy in minutes.</h2>
      <p>One container. Your hardware. No cloud account, no billing, no lock-in.</p>
      <div class="actions">
        <a href="#install" class="btn btn-primary">
          Get started
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="https://github.com/Harsh-2002/Orva" target="_blank" rel="noopener" class="btn btn-ghost">
          GitHub
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
        <a href="https://github.com/Harsh-2002/Orva/blob/main/docs/ARCHITECTURE.md" target="_blank" rel="noopener" class="btn btn-ghost">Architecture docs</a>
      </div>
    </div>
  </div>
</section>

<style>
  #cta {
    padding: clamp(72px, 9vw, 104px) 0;
    background: var(--surface);
    text-align: center;
  }
  .wrap { max-width: 480px; margin: 0 auto; }
  h2 { font-size: clamp(1.75rem, 3.5vw, 2.25rem); font-weight: 600; letter-spacing: -0.03em; margin-bottom: 10px; }
  p { font-size: 1rem; color: var(--muted); margin-bottom: 28px; line-height: 1.6; }
  .actions { display: flex; align-items: center; justify-content: center; gap: 10px; flex-wrap: wrap; }

  @media (max-width: 480px) {
    .actions { flex-direction: column; }
    .actions .btn { width: 100%; justify-content: center; }
  }
</style>
