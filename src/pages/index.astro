---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const baseTrim = base.replace(/\/$/, '');

// Fetch latest release tag at build time (best-effort; falls back gracefully)
let latestVersion = 'v2026.05.13';
let latestUrl = 'https://github.com/Harsh-2002/Orva/releases/latest';
try {
  const r = await fetch('https://api.github.com/repos/Harsh-2002/Orva/releases/latest', {
    headers: {
      Accept: 'application/vnd.github+json',
      'User-Agent': 'orva-site-build',
      ...(process.env.GITHUB_TOKEN ? { Authorization: `Bearer ${process.env.GITHUB_TOKEN}` } : {}),
    },
  });
  if (r.ok) {
    const j: { tag_name?: string; html_url?: string } = await r.json();
    if (j.tag_name) latestVersion = j.tag_name;
    if (j.html_url) latestUrl = j.html_url;
  }
} catch {
  /* offline build or rate-limit — keep fallback */
}

const capabilities: [string, string][] = [
  ['Multi-runtime', 'Node.js 22/24, Python 3.13/3.14, TypeScript — all in one binary.'],
  [
    'nsjail isolation',
    'Five overlapping Linux kernel boundaries per call — user NS, mount NS, cgroup v2, seccomp, network NS.',
  ],
  [
    'Warm pools',
    'Idle workers stay resident between invocations. Pool size configurable per function; back-to-back calls skip spawn entirely.',
  ],
  [
    'KV store',
    'Per-function SQLite-backed KV with optional TTL. kv.put / kv.get / kv.list — browsable from the dashboard.',
  ],
  [
    'Background jobs',
    'jobs.enqueue(name, payload). Persisted queue with configurable retries and exponential backoff.',
  ],
  [
    'Cron schedules',
    'Fire any function on a cron expression. Dashboard shows last run, next run, current status.',
  ],
  [
    'Function-to-function',
    'invoke("name", payload) calls another function via the warm pool as a child span in the same trace.',
  ],
  [
    'Distributed tracing',
    'HTTP, F2F calls, and background jobs share one trace_id. Waterfall view in dashboard; zero code changes.',
  ],
  [
    'Custom routes',
    'Map a path like /webhooks/stripe to a function so callers use a clean URL instead of a UUID.',
  ],
  [
    'Secrets',
    'Encrypted per-function secrets injected as env vars at sandbox spawn time. Never logged, never plaintext on disk.',
  ],
  [
    'Inbound webhooks',
    'Signed external trigger endpoints — GitHub, Stripe, Slack, and generic HMAC — fanning into a function.',
  ],
  ['Rollback', 'Every deploy is content-hashed and archived. Roll back to any prior version in one click.'],
  [
    'MCP server',
    '70 tools at /mcp. Claude Code, Cursor, and any OAuth MCP client can deploy and manage functions from chat.',
  ],
  [
    '16 templates',
    'Stripe webhooks, GitHub events, JWT auth, OAuth, CSV→JSON, URL shortener — pickable in the editor.',
  ],
];

const layers: [string, string][] = [
  [
    'User namespace',
    'UID 0 inside the sandbox maps to UID 65534 (nobody) on the host. All 64 Linux capability bits cleared — verified via /proc/self/status. The function cannot escalate to host root.',
  ],
  [
    'Mount namespace + chroot',
    "/code is a read-only bind mount of the function's versioned directory. /tmp is a private tmpfs wiped after each worker exits. No host filesystem visible.",
  ],
  [
    'cgroup v2',
    'Hard limits per function: memory.max, cpu.max, pids.max. The host refuses new spawns past 80% total memory reservation.',
  ],
  [
    'Seccomp (Kafel policy)',
    '~150 syscalls blocked: mount, unshare, bpf, kexec_load, init_module, ptrace, and more. Blocked attempts log and kill the process — never silently fail.',
  ],
  [
    'Network namespace',
    'Default network_mode: none — loopback only, no inbound possible. Functions opt in to network_mode: egress for outbound HTTPS via an nftables allowlist.',
  ],
];

const compareRows: [string, string, string, string][] = [
  ['Kernel', 'Shared with host', 'Separate per VM', 'Shared with host'],
  [
    'Isolation primitive',
    'Linux namespaces + seccomp + cgroup v2',
    'Hardware virtualisation (KVM)',
    'Linux namespaces + cgroup',
  ],
  [
    'Syscall surface',
    '~150 syscalls blocked via Kafel policy',
    'Near-zero (hardware boundary)',
    'Unfiltered by default',
  ],
  ['Capability drop', 'All 64 Linux caps cleared', 'N/A (separate kernel)', 'Partial (Docker defaults)'],
  ['Cold start', '~50–200 ms', '~125 ms (Firecracker MicroVM)', 'N/A'],
  ['Memory / worker', '~30 MB', '~5 MB per MicroVM', 'Varies'],
  [
    'Suited for',
    'Homelabs, internal tools, trusted code',
    'Multi-tenant cloud, untrusted code',
    'General app containers',
  ],
];

const shots: [string, string, string][] = [
  ['system-overview-dashboard', 'System overview', 'Live metrics, warm pools, response-time percentiles'],
  ['functions-list', 'Functions', 'Every deployed handler, runtime, resources, last deploy date'],
  ['function-editor', 'Editor', 'Write and deploy code directly in the browser'],
  ['distributed-traces', 'Traces', 'Automatic causal waterfall across HTTP, F2F, and background jobs'],
  ['activity-live-feed', 'Activity', 'Live feed of every API call, CLI command, and webhook delivery'],
  ['invocation-logs', 'Invocation logs', 'Every execution with request, response, duration, trace link'],
  ['built-in-docs', 'Docs', 'Full reference always at /web/docs — no tab-switching'],
  ['firewall-and-dns', 'Firewall & DNS', 'Per-function egress rules, custom resolvers, blocklist'],
  ['settings-oauth', 'Settings', 'Storage, account, and OAuth-connected apps'],
];
---

<Layout title="Orva — self-hosted serverless runtime">
  <!-- ── Masthead ─────────────────────────────────────── -->
  <header class="masthead">
    <div class="inner mast-inner">
      <a class="brand" href="#top" aria-label="Orva — home">
        <svg class="brand-mark" viewBox="0 0 32 32" aria-hidden="true">
          <rect width="32" height="32" rx="8" fill="currentColor"></rect>
          <text
            x="16"
            y="21"
            font-family="Inter, system-ui, sans-serif"
            font-size="13"
            font-weight="700"
            fill="#fff"
            text-anchor="middle"
            letter-spacing="-0.5">f(x)</text
          >
        </svg>
        <span class="brand-name">Orva</span>
      </a>
      <nav class="nav-primary" aria-label="Primary">
        <a href="#capabilities">Capabilities</a>
        <a href="#isolation">Isolation</a>
        <a href="#dashboard">Dashboard</a>
        <a href="#install">Install</a>
        <a class="nav-ext" href="https://github.com/Harsh-2002/Orva" target="_blank" rel="noopener">
          GitHub <span aria-hidden="true">↗</span>
        </a>
      </nav>
    </div>
  </header>

  <!-- ── Hero ─────────────────────────────────────────── -->
  <section class="hero" id="top">
    <div class="inner hero-inner">
      <div class="hero-meta">
        <a
          class="overline ver-pill"
          href={latestUrl}
          target="_blank"
          rel="noopener"
          aria-label={`Latest release ${latestVersion} on GitHub`}
        >
          <span class="ver-dot" aria-hidden="true"></span>
          {latestVersion} · latest
        </a>
        <span class="hero-meta-sep" aria-hidden="true">/</span>
        <span class="hero-meta-build">self-hosted · MIT</span>
      </div>

      <h1>
        Functions on<br />
        <span class="h1-em">your own metal.</span>
      </h1>

      <p class="hero-lede">
        Node, Python, and TypeScript. Five kernel-enforced boundaries per call. One binary, one port, zero
        external dependencies.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="#install">Install — 30 seconds</a>
        <a class="btn btn-ghost" href="https://github.com/Harsh-2002/Orva" target="_blank" rel="noopener">
          github.com/Harsh-2002/Orva <span aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="hero-cmd code">
        <div class="code-bar">
          <span>~ /</span>
          <button class="copy" data-copy="#hero-cmd-text">Copy</button>
        </div>
        <pre
          id="hero-cmd-text"><code>docker run -d --name orva -p 8443:8443 ghcr.io/harsh-2002/orva:latest</code></pre>
      </div>

      <p class="hero-foot">
        Open <code>https://localhost:8443</code> · onboarding takes ~30 seconds.
      </p>
    </div>
  </section>

  <!-- ── 01 / Capabilities ────────────────────────────── -->
  <section class="sec" id="capabilities">
    <div class="inner">
      <header class="sec-head">
        <span class="num">01</span>
        <span class="slash">/</span>
        <span class="label">Capabilities</span>
        <span class="bar"></span>
        <span class="count">14 items</span>
      </header>

      <h2>Fourteen things.<br />One container.</h2>
      <p class="sec-sub">
        Everything an operator needs to run untrusted code — observed, reversible, no external dependencies,
        no add-on services.
      </p>

      <dl class="caps">
        {
          capabilities.map(([name, desc]) => (
            <div class="cap">
              <dt>{name}</dt>
              <dd>{desc}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- ── 02 / Isolation ───────────────────────────────── -->
  <section class="sec" id="isolation">
    <div class="inner">
      <header class="sec-head">
        <span class="num">02</span>
        <span class="slash">/</span>
        <span class="label">Isolation</span>
        <span class="bar"></span>
        <span class="count">5 layers</span>
      </header>

      <h2>Five overlapping<br />kernel boundaries.</h2>
      <p class="sec-sub">
        Each layer is enforced by the kernel, not by Orva. Orva configures the boundaries; the kernel holds
        them.
      </p>

      <ol class="layers">
        {
          layers.map(([title, body], i) => (
            <li class="layer">
              <span class="layer-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="layer-body">
                <h3>{title}</h3>
                <p>{body}</p>
              </div>
            </li>
          ))
        }
      </ol>

      <div class="compare-wrap">
        <table class="compare">
          <thead>
            <tr>
              <th scope="col"></th>
              <th scope="col">Orva (nsjail)</th>
              <th scope="col">Firecracker / VMs</th>
              <th scope="col">Plain Docker</th>
            </tr>
          </thead>
          <tbody>
            {
              compareRows.map(([k, a, b, c]) => (
                <tr>
                  <th scope="row">{k}</th>
                  <td class="hl">{a}</td>
                  <td>{b}</td>
                  <td>{c}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <p class="sec-foot">
        Full threat model and self-verification recipe:&nbsp;
        <a
          href="https://github.com/Harsh-2002/Orva/blob/main/docs/SECURITY.md"
          target="_blank"
          rel="noopener"
        >
          docs/SECURITY.md
        </a>. Verified end-to-end under Kata Containers 3.30 (QEMU + Cloud Hypervisor); the nsjail boundary
        holds unchanged with a real Linux kernel underneath.
      </p>
    </div>
  </section>

  <!-- ── 03 / Dashboard ───────────────────────────────── -->
  <section class="sec" id="dashboard">
    <div class="inner">
      <header class="sec-head">
        <span class="num">03</span>
        <span class="slash">/</span>
        <span class="label">Dashboard</span>
        <span class="bar"></span>
        <span class="count">9 views</span>
      </header>

      <h2>Everything the operator needs.<br />Nothing they don't.</h2>
      <p class="sec-sub">Click any screenshot for full size.</p>

      <div class="shots">
        {
          shots.map(([file, title, desc]) => {
            const src = `${baseTrim}/screenshots/${file}.jpeg`;
            const cap = `${title} — ${desc}`;
            return (
              <figure class="shot">
                <div
                  class="shot-thumb"
                  role="button"
                  tabindex="0"
                  data-lightbox={src}
                  data-caption={cap}
                  aria-label={`View ${title} full size`}
                >
                  <img src={src} alt={title} loading="lazy" decoding="async" width="800" height="500" />
                </div>
                <figcaption>
                  <strong>{title}</strong>
                  <span>{desc}</span>
                </figcaption>
              </figure>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- ── 04 / Install ─────────────────────────────────── -->
  <section class="sec" id="install">
    <div class="inner">
      <header class="sec-head">
        <span class="num">04</span>
        <span class="slash">/</span>
        <span class="label">Install</span>
        <span class="bar"></span>
        <span class="count">3 paths</span>
      </header>

      <h2>Three ways in.<br />Pick the one you trust.</h2>

      <div class="install-stack">
        <article class="install-opt">
          <header>
            <span class="opt-letter" aria-hidden="true">A</span>
            <div>
              <h3>Docker</h3>
              <p>The fast path. One command, a persistent volume, exposes <code>:8443</code>.</p>
            </div>
          </header>
          <div class="code">
            <div class="code-bar">
              <span>shell</span>
              <button class="copy" data-copy="#install-docker">Copy</button>
            </div>
            <pre
              id="install-docker"><code>{`docker run -d \\
  --name orva \\
  -p 8443:8443 \\
  -v orva-data:/var/lib/orva \\
  ghcr.io/harsh-2002/orva:latest`}</code></pre>
          </div>
        </article>

        <article class="install-opt">
          <header>
            <span class="opt-letter" aria-hidden="true">B</span>
            <div>
              <h3>Docker Compose</h3>
              <p>Pin a tag, declare the volume, keep your <code>compose.yml</code> in version control.</p>
            </div>
          </header>
          <div class="code">
            <div class="code-bar">
              <span>compose.yml</span>
              <button class="copy" data-copy="#install-compose">Copy</button>
            </div>
            <pre
              id="install-compose"><code>{`services:
  orva:
    image: ghcr.io/harsh-2002/orva:latest
    restart: unless-stopped
    ports:
      - "8443:8443"
    volumes:
      - orva-data:/var/lib/orva

volumes:
  orva-data:`}</code></pre>
          </div>
        </article>

        <article class="install-opt">
          <header>
            <span class="opt-letter" aria-hidden="true">C</span>
            <div>
              <h3>Standalone CLI</h3>
              <p>No daemon, no Docker. Single binary, systemd unit, native nsjail.</p>
            </div>
          </header>
          <div class="code">
            <div class="code-bar">
              <span>shell</span>
              <button class="copy" data-copy="#install-cli">Copy</button>
            </div>
            <pre
              id="install-cli"><code>{`curl -fsSL https://orva.dev/install.sh | sh
sudo systemctl enable --now orva`}</code></pre>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ── 05 / Runtimes ────────────────────────────────── -->
  <section class="sec" id="runtimes">
    <div class="inner">
      <header class="sec-head">
        <span class="num">05</span>
        <span class="slash">/</span>
        <span class="label">Runtimes</span>
        <span class="bar"></span>
        <span class="count">3 languages</span>
      </header>

      <h2>Write a function.<br />Get a URL.</h2>
      <p class="sec-sub">
        Every handler is a default export. <code>kv</code>, <code>invoke</code>, and <code>jobs</code> are pre-installed
        — no <code>npm install</code>, no <code>pip install</code>.
      </p>

      <div class="install-stack">
        <article class="install-opt">
          <header>
            <span class="opt-letter" aria-hidden="true">A</span>
            <div>
              <h3>Node.js <span class="opt-meta">22 · 24</span></h3>
              <p>
                Default export an async handler. <code>ctx.kv</code> backed by per-function SQLite; no install needed.
              </p>
            </div>
          </header>
          <div class="code">
            <div class="code-bar">
              <span>handler.js</span>
              <button class="copy" data-copy="#rt-node">Copy</button>
            </div>
            <pre
              id="rt-node"><code>{`export default async function (req, ctx) {
  const seen = (await ctx.kv.get('count')) ?? 0;
  await ctx.kv.put('count', seen + 1);
  return { ok: true, seen: seen + 1 };
}`}</code></pre>
          </div>
        </article>

        <article class="install-opt">
          <header>
            <span class="opt-letter" aria-hidden="true">B</span>
            <div>
              <h3>Python <span class="opt-meta">3.13 · 3.14</span></h3>
              <p>
                Plain <code>async def handler(req, ctx)</code>. Async SDK on <code>ctx</code> — no FastAPI, no boilerplate.
              </p>
            </div>
          </header>
          <div class="code">
            <div class="code-bar">
              <span>handler.py</span>
              <button class="copy" data-copy="#rt-py">Copy</button>
            </div>
            <pre
              id="rt-py"><code>{`async def handler(req, ctx):
    seen = await ctx.kv.get('count') or 0
    await ctx.kv.put('count', seen + 1)
    return {'ok': True, 'seen': seen + 1}`}</code></pre>
          </div>
        </article>

        <article class="install-opt">
          <header>
            <span class="opt-letter" aria-hidden="true">C</span>
            <div>
              <h3>TypeScript <span class="opt-meta">native</span></h3>
              <p>
                Types ship with the runtime — <code>import type &#123; OrvaHandler &#125; from 'orva'</code> and
                you're set.
              </p>
            </div>
          </header>
          <div class="code">
            <div class="code-bar">
              <span>handler.ts</span>
              <button class="copy" data-copy="#rt-ts">Copy</button>
            </div>
            <pre
              id="rt-ts"><code>{`import type { OrvaHandler } from 'orva';

const handler: OrvaHandler = async (req, ctx) => {
  await ctx.jobs.enqueue('thumbnail', { url: req.body.url });
  return { queued: true };
};
export default handler;`}</code></pre>
          </div>
        </article>
      </div>

      <p class="sec-foot">
        Full SDK surface on <code>ctx</code>: <code>kv</code>, <code>invoke</code>, <code>jobs</code>,
        <code>logger</code>, <code>trace</code>, <code>secrets</code>. Reference docs ship in-product at <code
          >/web/docs</code
        >.
      </p>
    </div>
  </section>

  <!-- ── Closing ──────────────────────────────────────── -->
  <section class="sec close">
    <div class="inner">
      <p class="overline overline-block">— Last word</p>
      <h2>One binary.<br />Boring on purpose.</h2>
      <p class="hero-lede close-lede">
        No control plane. No telemetry. No vendor account. Your hardware, your code, your kernel boundaries.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#install">Install</a>
        <a class="btn btn-ghost" href="https://github.com/Harsh-2002/Orva" target="_blank" rel="noopener">
          Star on GitHub <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Masthead ─────────────────────────────────────────── */
  .masthead {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: transparent;
    transform: translate3d(0, 0, 0);
    transition: transform 320ms cubic-bezier(0.22, 0.8, 0.2, 1);
    will-change: transform;
  }
  .masthead.is-hidden {
    transform: translate3d(0, -100%, 0);
  }
  @media (prefers-reduced-motion: reduce) {
    .masthead {
      transition: none;
    }
  }
  .mast-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  @media (max-width: 480px) {
    .mast-inner {
      height: 64px;
    }
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--brand);
    transition: transform 200ms ease;
  }
  .brand:active {
    transform: scale(0.97);
  }
  .brand-mark {
    width: 34px;
    height: 34px;
    display: block;
    flex-shrink: 0;
  }
  .brand-name {
    font-family: var(--sans);
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--fg);
    line-height: 1;
  }
  @media (max-width: 480px) {
    .brand {
      gap: 10px;
    }
    .brand-mark {
      width: 30px;
      height: 30px;
    }
    .brand-name {
      font-size: 1.1875rem;
    }
  }

  .nav-primary {
    display: flex;
    align-items: center;
    gap: 28px;
    font-size: 0.8125rem;
    font-family: var(--mono);
    letter-spacing: -0.005em;
  }
  .nav-primary a {
    color: var(--muted);
    transition: color 120ms;
  }
  .nav-primary a:hover {
    color: var(--fg);
  }
  .nav-primary .nav-ext {
    color: var(--accent-hi);
  }
  .nav-primary .nav-ext:hover {
    color: var(--fg);
  }

  @media (max-width: 720px) {
    .nav-primary {
      gap: 16px;
      font-size: 0.75rem;
    }
    .nav-primary a:not(.nav-ext) {
      display: none;
    }
  }

  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    padding: clamp(80px, 13vw, 150px) 0 clamp(72px, 11vw, 120px);
    border-top: none;
  }
  .hero-inner {
    max-width: var(--max);
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 36px;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .hero-meta-sep {
    color: var(--faint);
  }
  .hero-meta-build {
    color: var(--subtle);
  }

  .ver-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--accent-hi);
    border: 1px solid var(--border-hi);
    padding: 4px 10px;
    transition:
      background 140ms,
      border-color 140ms,
      color 140ms;
  }
  .ver-pill:hover {
    background: var(--surface);
    color: var(--fg);
    border-color: var(--fg);
  }
  .ver-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--green) 22%, transparent);
    animation: ver-pulse 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes ver-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.55;
    }
  }
  @media (max-width: 480px) {
    .hero-meta {
      flex-wrap: wrap;
      gap: 10px;
    }
    .hero-meta-sep {
      display: none;
    }
  }

  .hero h1 {
    margin-bottom: 30px;
  }
  .h1-em {
    color: var(--muted);
  }

  .hero-lede {
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    max-width: 56ch;
    color: var(--muted);
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
